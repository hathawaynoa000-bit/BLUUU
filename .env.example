# Server Configuration
PORT=5001
NODE_ENV=production
JWT_SECRET=your_jwt_secret_key_here

# PostgreSQL Database Configuration
# In hosting sites like Render/Railway/Heroku, this is populated automatically as DATABASE_URL.
# For manual setup, configure DATABASE_URL directly:
DATABASE_URL=postgresql://postgres:password@localhost:5432/bluuu_booth

# Alternatively, set individual database parameters (if DATABASE_URL is not set):
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=bluuu_booth
DB_PORT=5432

# Default Admin User Credentials (Created via 'npm run db:seed')
ADMIN_USER=admin
ADMIN_PASS=adminpinkglass
